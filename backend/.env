# =============================================
#  AI Voice Translator - Node.js Backend .env
#  ALL services run through OpenRouter only.
#  You do NOT need OpenAI, LibreTranslate,
#  or ElevenLabs keys — just the one below.
# =============================================

# Server
PORT=5000
NODE_ENV=development

# ── MongoDB Connection ───────────────────────
# 1. MongoDB Atlas (Cloud) - Requires network access
MONGO_URI=mongodb+srv://suryaj:surya%40@cluster0.w4s0i90.mongodb.net/ai_voice_assistant?retryWrites=true&w=majority&appName=Cluster0

# 2. Local MongoDB (Fallback) - Use if Atlas is blocked
# To use this: Install MongoDB locally and uncomment the line below
# MONGO_URI=mongodb://localhost:27017/ai_voice_assistant

# ── OpenRouter (single key for STT + Translation + TTS) ──
# All three services are routed through OpenRouter.
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# ── STT: which Whisper endpoint to use ────
# "openrouter" = use OpenRouter's whisper proxy (default, no extra key needed)
# "openai"     = use OpenAI directly (requires OPENAI_API_KEY below)
STT_PROVIDER=openrouter

# Leave blank — not needed when STT_PROVIDER=openrouter
OPENAI_API_KEY=

# ── Translation: OpenRouter LLM ───────────
# Model used for translation via OpenRouter
# Free options: "mistralai/mistral-7b-instruct" | "google/gemma-3-4b-it:free"
# Paid options: "openai/gpt-3.5-turbo" | "openai/gpt-4o-mini"
TRANSLATION_MODEL=mistralai/mistral-7b-instruct

# ── TTS: which provider to use ────────────
# "openrouter" = use OpenRouter's TTS-compatible model (default)
# "device"     = skip server TTS, let Flutter use on-device flutter_tts (free)
# "elevenlabs" = high-quality multilingual TTS (requires ELEVENLABS_API_KEY)
TTS_PROVIDER=device

# Leave blank unless TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=

# ── App ───────────────────────────────────
JWT_SECRET=ai_voice_translator_secret_2024
MAX_AUDIO_SIZE=10485760
